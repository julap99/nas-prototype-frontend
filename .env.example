# =============================================================================
# FRONTEND ENVIRONMENT CONFIGURATION
# =============================================================================

# -----------------------------------------------------------------------------
# API Configuration
# -----------------------------------------------------------------------------
# Backend API Base URL
NUXT_API_BASE_URL=http://localhost:3001

# -----------------------------------------------------------------------------
# Authentication Configuration
# -----------------------------------------------------------------------------
# JWT Secret for Access Tokens (should match backend)
NUXT_ACCESS_TOKEN_SECRET=your-access-token-secret-key-here

# JWT Secret for Refresh Tokens (should match backend)
NUXT_REFRESH_TOKEN_SECRET=your-refresh-token-secret-key-here

# -----------------------------------------------------------------------------
# Metabase Configuration
# -----------------------------------------------------------------------------
# Metabase Secret Key for dashboard embedding
NUXT_METABASE_SECRET_KEY=c98a5b005450e699b6d420f46e0062912ac75268716f1298c11d8bb11c291eb0

# Metabase Site URL
NUXT_METABASE_SITE_URL=http://mb.sena.my

# -----------------------------------------------------------------------------
# Application Configuration
# -----------------------------------------------------------------------------
# Application Environment (development, staging, production)
NODE_ENV=development

# Port for development server (optional, defaults to 3000)
NUXT_PORT=3000

# Host for development server (optional, defaults to localhost)
NUXT_HOST=localhost

# -----------------------------------------------------------------------------
# Security Configuration
# -----------------------------------------------------------------------------
# CORS Origin (for production, set to your domain)
NUXT_CORS_ORIGIN=http://localhost:3000

# -----------------------------------------------------------------------------
# Database Configuration (if needed for direct database access)
# -----------------------------------------------------------------------------
# Note: Usually frontend doesn't need direct database access
# These are commented out but available if needed
# NUXT_DB_HOST=localhost
# NUXT_DB_PORT=3306
# NUXT_DB_NAME=nas_db
# NUXT_DB_USER=root
# NUXT_DB_PASSWORD=

# -----------------------------------------------------------------------------
# Third-party Service Configuration
# -----------------------------------------------------------------------------
# Google reCAPTCHA (if enabled)
# NUXT_RECAPTCHA_SITE_KEY=your-recaptcha-site-key-here

# Analytics (if needed)
# NUXT_ANALYTICS_ID=your-analytics-id-here

# -----------------------------------------------------------------------------
# Feature Flags
# -----------------------------------------------------------------------------
# Enable/disable mock data (true for development, false for production)
NUXT_USE_MOCK_DATA=true

# Enable/disable debug mode
NUXT_DEBUG=true

# -----------------------------------------------------------------------------
# File Upload Configuration
# -----------------------------------------------------------------------------
# Maximum file upload size (in bytes)
NUXT_MAX_FILE_SIZE=10485760

# Allowed file types for uploads
NUXT_ALLOWED_FILE_TYPES=jpg,jpeg,png,pdf,doc,docx

# -----------------------------------------------------------------------------
# Email Configuration (if needed for notifications)
# -----------------------------------------------------------------------------
# NUXT_SMTP_HOST=smtp.gmail.com
# NUXT_SMTP_PORT=587
# NUXT_SMTP_USER=your-email@gmail.com
# NUXT_SMTP_PASS=your-app-password
